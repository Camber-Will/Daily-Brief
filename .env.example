# Copy this file to .env and fill in your values
# NEVER commit the .env file — it contains your secrets

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────
# Get this at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Google (Calendar + Gmail) ─────────────────────────────────────────────
# Paste the full JSON content from your credentials.json here (one line)
GOOGLE_CREDENTIALS={"installed":{"client_id":"...","client_secret":"...",...}}

# The refresh token from running: python scripts/generate_token.py
GOOGLE_REFRESH_TOKEN=1//0g...

# ── Email Delivery ────────────────────────────────────────────────────────
# Where to send the daily brief (your Gmail address)
BRIEF_RECIPIENT_EMAIL=you@gmail.com

# ── Granola Notes (Optional) ─────────────────────────────────────────────
# Path to your Granola notes export folder (leave blank to skip)
# On Mac, Granola saves notes to ~/Library/Application Support/Granola/notes/
# Or set a folder where you export notes manually
GRANOLA_NOTES_DIR=
